DK_MIs_fnc_managePosCmpltd = {

	params [["_getOldPos", false]];

	private "_oldsPos";
	call
	{
		if _getOldPos exitWith
		{
			private "_nil";
			_oldsPos = +DK_MIS_posStart_K01_compltd;

			for "_i" from 0 to (count DK_MIS_posStart_K03_compltd) - 1 do
			{
				_nil = _oldsPos pushBackUnique ((DK_MIS_posStart_K03_compltd # _i) # 1);
			};

			for "_i" from 0 to (count DK_MIS_posStart_K04_compltd) - 1 do
			{
				_nil = _oldsPos pushBackUnique ((DK_MIS_posStart_K04_compltd # _i) # 1);
			};

			for "_i" from 0 to (count DK_MIS_posStart_TC01_compltd) - 1 do
			{
				_nil = _oldsPos pushBackUnique ((DK_MIS_posStart_TC01_compltd # _i) # 1);
			};
		};

		_oldsPos = [0,0,0];
	};

	if (DK_nbMisCpltd in [4,8,12,16,20,24,28,32,36,40,44,48]) then
	{
		DK_MIS_searchMissFar = true;
	};


	_oldsPos
};

DK_MIS_fnc_slctSafePlace_01 = {		// Kill 01 (large place in country side)

	private _oldsPos = [true] call DK_MIs_fnc_managePosCmpltd;

	private _time = time + 6;
	private _timeInit = time + 10;
	private _timeInit2 = _timeInit + 10;
	private _timeHard = time + 30;	///////
	private _posNfo = ( +(DK_MIS_posStart_K01 # 0) +(DK_MIS_posStart_K01_custom) ) - DK_MIS_posStart_K01_compltd;
	private _blacklDisMax = blackList_DisMax;
	private _slctLp = 0;
	private _exit = false;
	private _startPos = [0,0,0];
	private _disOtherPos = disOtherPos_K;	/////////
	private _disOtherPosFar = disOtherPosFar;	///////
	private ["_startPosASL", "_next", "_nul", "_debugPos"];

	while { true } do
	{
		if (_posNfo isEqualTo []) then
		{
			if (_slctLp isEqualTo 0) then
			{
				_posNfo = ( +(DK_MIS_posStart_K01 # _slctLp) +(DK_MIS_posStart_K01_custom) ) - DK_MIS_posStart_K01_compltd;
				_slctLp = 1;
			};
			if (_slctLp isEqualTo 1) then
			{
				_posNfo = ( +(DK_MIS_posStart_K01 # _slctLp) +(DK_MIS_posStart_K01_custom) ) - DK_MIS_posStart_K01_compltd;
				_slctLp = 0;
			};

			_nul = _posNfo deleteAt (_posNfo find _startPos);
		};

		_startPos = selectRandom _posNfo;

		if (isNil "_startPos") then
		{
			_disOtherPos = 0;
			_disOtherPosFar = 0;

			_debugPos = DK_MIS_posStart_K01 # 0;

			if !(_debugPos isEqualTo []) then
			{
				_startPos = selectRandom _debugPos;
			}
			else
			{
				if !(DK_MIS_posStart_K01_custom isEqualTo []) then
				{
					_startPos = selectRandom DK_MIS_posStart_K01_custom;
				}
				else
				{
					_debugPos = DK_MIS_posStart_K01 # 1;

					if !(_debugPos isEqualTo []) then
					{
						_startPos = selectRandom _debugPos;
					};
				};
			};
		};

		_next = true;

		call
		{
			if (time < _timeInit) exitWith
			{
				_startPosASL = AGLToASL (_startPos getPos [0,0]);

		//		if ( (playableUnits findIf { _x distance2D _startPos < place_DisMax_K01a } isEqualTo -1) OR !(_oldsPos findIf {_startPos distance2D _x < _disOtherPos} isEqualTo -1) OR !(playableUnits findIf { [vehicle _x, "IFIRE"] checkVisibility [eyePos _x, _startPosASL] > 0.5 } isEqualTo -1) ) then
				if ( !(_oldsPos findIf {_startPos distance2D _x < _disOtherPos} isEqualTo -1) OR (playableUnits findIf { _x distance2D _startPos < place_DisMax_K01a } isEqualTo -1) OR !(playableUnits findIf { !(lineIntersects [_x call DK_fnc_eyePlace, _startPosASL]) } isEqualTo -1) ) then
				{
					_next = false;
				};
			};

			if ( (time > _timeInit) && { (playableUnits findIf { _x distance2D _startPos < 9000 } isEqualTo -1) OR !(_oldsPos findIf {_startPos distance2D _x < _disOtherPosFar} isEqualTo -1) } ) exitWith
			{
				_next = false;
			};

			if DK_MIS_searchMissFar exitWith
			{
				if (time < _timeInit) then
				{
					_startPosASL = AGLToASL (_startPos getPos [0,0]);

					if ( (playableUnits findIf { _x distance2D _startPos < place_DisMax_K01b } isEqualTo -1) OR !(playableUnits findIf { !(lineIntersects [_x call DK_fnc_eyePlace, _startPosASL]) } isEqualTo -1) ) then
					{
						_next = false;
					};
				};

				if ( (_next) && { (_oldsPos findIf {_startPos distance2D _x < _disOtherPosFar} isEqualTo -1) && { (playableUnits findIf { _x distance2D _startPos < blackList_DisMaxFar } isEqualTo -1) && { (PlaceOK(_startPos,37,30)) } } } ) then
				{
					_next = false;
					_exit = true;
				};
			};

			if (time > _timeHard) then
			{
				if ( !(playableUnits findIf { _x distance2D _startPos < disHardTime } isEqualTo -1) OR !(PlaceOK(_startPos,37,30)) ) then
				{
					_next = false;
				};
			};
		};

		if ( (_next) && { (playableUnits findIf { _x distance2D _startPos < _blacklDisMax } isEqualTo -1) && { (PlaceOK(_startPos,37,30)) } } ) then
		{
				_exit = true;
		};

		if _exit exitWith {};


	///	// Only if NOT position find
		if (time > _time) then
		{
			_blacklDisMax = _blacklDisMax - 100;
			if (_blacklDisMax < blackList_DisMin ) then
			{
				_blacklDisMax = blackList_DisMax / 2;
			};

			if !(_disOtherPos isEqualTo 1) then
			{
				_disOtherPos = _disOtherPos - 75;
				if (_disOtherPos < 200) then
				{
					_disOtherPos = 1;
				};
			};

			if ( (DK_MIS_searchMissFar) OR (time > _timeInit2) && { !(_disOtherPosFar isEqualTo 1) } ) then
			{
				_disOtherPosFar = _disOtherPosFar - 75;
				if (_disOtherPosFar < 200) then
				{
					_disOtherPosFar = 1;
				};
			};

			_time = time + 3;
		};

		_nul = _posNfo deleteAt (_posNfo find _startPos);

		uiSleep 0.07;
	};

	_nul = DK_MIS_posStart_K01_compltd pushBackUnique _startPos;

	if (count DK_MIS_posStart_K01_compltd > 20) then
	{
		DK_MIS_posStart_K01_compltd = [];
	};


/*	// DEBUG
	hint ( "Dis player from miss: " + (str (player distance2D _startPos)) + "m. ; Schr time: " + (str (time - _debugTime)) + " ; Nb: " + (str DK_nbMisCpltd) + " ; Far: " + (str DK_MIS_searchMissFar) + " ; Type: Kill 01" );
	systemChat ( "Dis player from miss: " + (str (player distance2D _startPos)) + "m. ; Schr time: " + (str (time - _debugTime)) + " ; Nb: " + (str DK_nbMisCpltd) + " ; Far: " + (str DK_MIS_searchMissFar) + " ; Type: Kill 01" );

	private _mkrNzme = str DK_nbMisCpltd;
	private _markerstr = createMarker [_mkrNzme, _startPos];
//	_markerstr setMarkerShape "ELLIPSE";
	_markerstr setMarkerType "hd_dot";
	_mkrNzme setMarkerSize [1.5, 1.5];
	_mkrNzme setMarkerColor "ColorGreen";
	_markerstr setMarkerText _mkrNzme;
	// DEBUG
*/

	DK_MIS_searchMissFar = false;


	_startPos
};

