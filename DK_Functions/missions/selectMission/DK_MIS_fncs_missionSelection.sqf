DK_MIS_fnc_slctDifficultyLevel = {

	waitUntil { !(allPlayers isEqualTo []) };

	if !(DK_nbMisCpltd isEqualTo 0) then
	{
		uiSleep DK_timeBetweenMissions;
	}
	else
	{
		call DK_MIS_fnc_shuffleMissions;
	};

	// Count how many missions are completed
	DK_nbMisCpltd = DK_nbMisCpltd + DK_addNbMisCpltd;

	// Difficulty related to : Time elapsed since game was started
	call
	{
		_time = time;

		if ( _time < (DK_cntTmGameStart / 2) ) exitWith
		{
			call DK_MIS_fnc_slctMission_L1;
		};

		if ( _time >= (DK_cntTmGameStart / 2) ) then
		{
			call DK_MIS_fnc_slctMission_L1;
		};

	};
};


